{
  "manifest_version": 3,
  "default_locale": "ru",
  "name": "__MSG_extName__",
  "version": "1.8.2",
  "description": "__MSG_extDesc__",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "scripting", "activeTab", "offscreen", "tabCapture"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*",
    "https://rutube.ru/*",
    "https://*.rutube.ru/*",
    "https://vk.com/*",
    "https://*.vk.com/*",
    "https://vkvideo.ru/*",
    "https://*.okcdn.ru/*",
    "https://*.vkuser.net/*",
    "https://*.mycdn.me/*",
    "https://translate.googleapis.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://vk.com/*",
        "https://*.vk.com/*",
        "https://vkvideo.ru/*"
      ],
      "js": ["src/content/vk-net-hook.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["src/content/yt-net-hook.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://rutube.ru/*",
        "https://*.rutube.ru/*",
        "https://vk.com/*",
        "https://*.vk.com/*",
        "https://vkvideo.ru/*"
      ],
      "js": ["src/content/video-page.ts"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html"],
      "matches": [
        "https://www.youtube.com/*",
        "https://rutube.ru/*",
        "https://*.rutube.ru/*",
        "https://vk.com/*",
        "https://vkvideo.ru/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; form-action 'self';"
  }
}
